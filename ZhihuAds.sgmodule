#!name=知乎净化
#!desc=去除开屏广告、信息流广告、回答页推广、评论广告、营销消息，本地伪装 VIP 解锁关键词屏蔽
#!author=blackmatrix7 (hackevin 适配，脚本自托管)
#!version=3.1.0
#!system=ios

[Rule]
# HTTP DNS 广告 IP 拦截
IP-CIDR,118.89.204.198/32,REJECT,no-resolve
IP-CIDR,103.41.167.237/32,REJECT,no-resolve
IP-CIDR6,2402:4e00:1200:ed00:0:9089:6dac:96b6/128,REJECT,no-resolve

# 追踪/崩溃上报域名
DOMAIN,mqtt.zhihu.com,REJECT
DOMAIN,sugar.zhihu.com,REJECT
DOMAIN,crash2.zhihu.com,REJECT
DOMAIN,appcloud.zhihu.com,REJECT
DOMAIN,appcloud2.in.zhihu.com,REJECT
DOMAIN,duga.zhihu.com,REJECT
DOMAIN,apm.zhihu.com,REJECT

[Map Local]
# ---- 原 URL-REGEX REJECT 接口，改为返回空 JSON（避免 app 报网络错误）----

# 开屏广告
^https?://api\.zhihu\.com/commercial_api$ data="https://raw.githubusercontent.com/blackmatrix7/ios_rule_script/refs/heads/master/blank/blank_dict.json"
# 回答下方广告
^https?://api\.zhihu\.com/commercial_api/answer/\d+/bottom-v2 data="https://raw.githubusercontent.com/blackmatrix7/ios_rule_script/refs/heads/master/blank/blank_dict.json"
# 无用请求
^https?://api\.zhihu\.com/message-push/event data="https://raw.githubusercontent.com/blackmatrix7/ios_rule_script/refs/heads/master/blank/blank_dict.json"
# 付费回答营销引导
^https?://api\.zhihu\.com/guide_center/strategy data="https://raw.githubusercontent.com/blackmatrix7/ios_rule_script/refs/heads/master/blank/blank_dict.json"
# 会员页浮动广告
^https?://api\.zhihu\.com/bazaar/float_window data="https://raw.githubusercontent.com/blackmatrix7/ios_rule_script/refs/heads/master/blank/blank_dict.json"
# 数据上报
^https?://api\.zhihu\.com/metrics/report data="https://raw.githubusercontent.com/blackmatrix7/ios_rule_script/refs/heads/master/blank/blank_dict.json"
# 通知设置
^https?://api\.zhihu\.com/settings/new/notification data="https://raw.githubusercontent.com/blackmatrix7/ios_rule_script/refs/heads/master/blank/blank_dict.json"
# 会员相关广告
^https?://api\.zhihu\.com/bazaar/vip_tab/header data="https://raw.githubusercontent.com/blackmatrix7/ios_rule_script/refs/heads/master/blank/blank_dict.json"

# ---- 原有 Map Local 规则 ----

# 消息通知角标
^https?://api\.zhihu\.com/notifications/v\d/count data="https://raw.githubusercontent.com/blackmatrix7/ios_rule_script/refs/heads/master/blank/blank_dict.json"
# 推荐页顶部广告
^https?://api\.zhihu\.com/root/window data="https://raw.githubusercontent.com/blackmatrix7/ios_rule_script/refs/heads/master/blank/blank_dict.json"
# 应用内弹窗
^https?://api\.zhihu\.com/me/guides data="https://raw.githubusercontent.com/blackmatrix7/ios_rule_script/refs/heads/master/blank/blank_dict.json"
# 关注页最常访问
^https?://api\.zhihu\.com/moments/recent data="https://raw.githubusercontent.com/blackmatrix7/ios_rule_script/refs/heads/master/blank/blank_dict.json"
# 推荐页顶部广告2
^https?://api\.zhihu\.com/api/v4/ecom_data/config data="https://raw.githubusercontent.com/blackmatrix7/ios_rule_script/refs/heads/master/blank/blank_dict.json"
# 推荐页内容更新红点
^https?://api\.zhihu\.com/feed/render/revisit/tag_config data="https://raw.githubusercontent.com/blackmatrix7/ios_rule_script/refs/heads/master/blank/blank_dict.json"
# 推荐页 Tab Banner
^https?://api\.zhihu\.com/content-distribution-core/sections/ data="https://raw.githubusercontent.com/blackmatrix7/ios_rule_script/refs/heads/master/blank/blank_dict.json"

[Script]
# 获取用户信息，本地伪装 VIP
哲也_用户信息 = type=http-response,pattern=^https?://api\.zhihu\.com/people/,requires-body=true,max-size=0,script-path=https://raw.githubusercontent.com/hackevin/tiktok-ruleset/refs/heads/main/zhihu_adskip.js

# 关键词屏蔽（需本地 VIP）
哲也_关键词屏蔽 = type=http-request,pattern=^https?://api\.zhihu\.com/feed-root/block,requires-body=true,max-size=0,script-path=https://raw.githubusercontent.com/hackevin/tiktok-ruleset/refs/heads/main/zhihu_adskip.js

# 优化推荐页 Tab
哲也_推荐Tab = type=http-response,pattern=^https?://api\.zhihu\.com/root/tab/v2,requires-body=true,max-size=0,script-path=https://raw.githubusercontent.com/hackevin/tiktok-ruleset/refs/heads/main/zhihu_adskip.js

# 推荐页去广告、过滤黑名单
哲也_推荐页 = type=http-response,pattern=^https://(api|web-render)\.zhihu\.com/topstory/recommend,requires-body=true,max-size=0,timeout=30,script-path=https://raw.githubusercontent.com/hackevin/tiktok-ruleset/refs/heads/main/zhihu_adskip.js

# 回答列表去广告
哲也_回答列表 = type=http-response,pattern=^https://api\.zhihu\.com/questions/\d+/feeds,requires-body=true,max-size=0,script-path=https://raw.githubusercontent.com/hackevin/tiktok-ruleset/refs/heads/main/zhihu_adskip.js

# 回答信息流去广告
哲也_回答信息流 = type=http-response,pattern=^https?://api\.zhihu\.com/next-render,requires-body=true,max-size=0,script-path=https://raw.githubusercontent.com/hackevin/tiktok-ruleset/refs/heads/main/zhihu_adskip.js

# 消息页折叠官方消息
哲也_消息页 = type=http-response,pattern=^https?://api\.zhihu\.com/notifications/v3/(message|timeline/entry/system_message),requires-body=true,max-size=0,script-path=https://raw.githubusercontent.com/hackevin/tiktok-ruleset/refs/heads/main/zhihu_adskip.js

# 评论页过滤黑名单
哲也_评论页 = type=http-response,pattern=^https?://api\.zhihu\.com/(comment_v5/)?(answers|comments?|articles|pins)/\d+/(root_|child_)?comments?,requires-body=true,max-size=0,script-path=https://raw.githubusercontent.com/hackevin/tiktok-ruleset/refs/heads/main/zhihu_adskip.js

# 回答页移除相关推荐
哲也_回答页 = type=http-response,pattern=^https://(page-info|api)\.zhihu\.com/answers/v2/\d+,requires-body=true,max-size=0,script-path=https://raw.githubusercontent.com/hackevin/tiktok-ruleset/refs/heads/main/zhihu_adskip.js

# 文章页移除相关推荐
哲也_文章页 = type=http-response,pattern=^https://api\.zhihu\.com/articles/v\d/\d+,requires-body=true,max-size=0,script-path=https://raw.githubusercontent.com/hackevin/tiktok-ruleset/refs/heads/main/zhihu_adskip.js

# 关注页过滤黑名单
哲也_关注页 = type=http-response,pattern=^https?://api\.zhihu\.com/moments_v3\?,requires-body=true,max-size=0,script-path=https://raw.githubusercontent.com/hackevin/tiktok-ruleset/refs/heads/main/zhihu_adskip.js

# 热榜去广告
哲也_热榜 = type=http-response,pattern=^https?://api\.zhihu\.com/topstory/hot-lists[?/],requires-body=true,max-size=0,script-path=https://raw.githubusercontent.com/hackevin/tiktok-ruleset/refs/heads/main/zhihu_adskip.js

# 搜索页预置广告
哲也_搜索预置词 = type=http-response,pattern=^https?://api\.zhihu\.com/search/preset_words\?,requires-body=true,max-size=0,script-path=https://raw.githubusercontent.com/hackevin/tiktok-ruleset/refs/heads/main/zhihu_adskip.js

# 搜索页猜你想搜
哲也_猜你想搜 = type=http-response,pattern=^https?://api\.zhihu\.com/search/recommend_query,requires-body=true,max-size=0,script-path=https://raw.githubusercontent.com/hackevin/tiktok-ruleset/refs/heads/main/zhihu_adskip.js

# 黑名单同步
哲也_黑名单 = type=http-response,pattern=^https://api\.zhihu\.com/settings/blocked_users,requires-body=true,max-size=0,script-path=https://raw.githubusercontent.com/hackevin/tiktok-ruleset/refs/heads/main/zhihu_adskip.js

# 回答页底部评论摘要
哲也_评论摘要 = type=http-response,pattern=^https?://www\.zhihu\.com/api/v4/comment_v5/answers/\d+/abstract_comment\?,requires-body=true,max-size=0,script-path=https://raw.githubusercontent.com/hackevin/tiktok-ruleset/refs/heads/main/zhihu_adskip.js

[MITM]
hostname = %APPEND% www.zhihu.com,api.zhihu.com,zhuanlan.zhihu.com,m-cloud.zhihu.com,page-info.zhihu.com,web-render.zhihu.com
