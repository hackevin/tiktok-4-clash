# 广告域名直连（原配置 host-suffix direct，避免走代理影响广告过滤）
DOMAIN-SUFFIX,optimus-ads.amap.com,DIRECT
 
# 开屏广告接口
URL-REGEX,^https?://.*\.amap\.com/ws/aos/alimama/splash_screen,REJECT-TINYGIF
 
# 首页底部信息流
URL-REGEX,^https?://.*\.amap\.com/v\d/ai_rec/,REJECT
 
# 路线规划下方广告
URL-REGEX,^https?://.*\.amap\.com/ws/faas/amap-navigation/card-service-route-plan\?,REJECT
 
# 通用广告归因请求
URL-REGEX,^https?://.*\.amap\.com/ws/asa/ads_attribution,REJECT
 
# Tip 请求
URL-REGEX,^https?://.*\.amap\.com/ws/boss/order_web/\w{8}_information,REJECT-TINYGIF
 
# 首页左上角 GIF 推广图
URL-REGEX,^https?://.*\.amap\.com/uploadimg/\w+\.gif,REJECT-TINYGIF
 
# 左下天气推广
URL-REGEX,^https?://.*\.amap\.com/ws/valueadded/weather,REJECT
 
# amdc（淘宝广告平台）
URL-REGEX,^http://amdc\.m\.taobao\.com,REJECT
