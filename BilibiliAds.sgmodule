#!name=B站去广告
#!desc=开屏广告、推荐页广告卡片、直播间广告、底部Tab净化
#!author=Claude
#!version=1.0.0
#!system=ios

[Rule]
# B站广告追踪域名
DOMAIN,adfront.bilibili.com,REJECT
DOMAIN,data.bilibili.com,REJECT

[Map Local]
# 开屏广告
^https?://app\.bilibili\.com/x/v2/splash data="https://raw.githubusercontent.com/blackmatrix7/ios_rule_script/refs/heads/master/blank/blank_dict.json"
^https?://api\.bilibili\.com/x/v2/splash data="https://raw.githubusercontent.com/blackmatrix7/ios_rule_script/refs/heads/master/blank/blank_dict.json"

[Script]
# 推荐页广告卡片过滤
B站_推荐页 = type=http-response,pattern=^https?://app\.bilibili\.com/x/v2/feed/index,requires-body=true,max-size=0,script-path=https://raw.githubusercontent.com/hackevin/tiktok-ruleset/refs/heads/main/bilibili_adskip.js

# 底部Tab净化（移除会员购、游戏中心）
B站_Tab净化 = type=http-response,pattern=^https?://app\.bilibili\.com/x/v2/resource/show/tab,requires-body=true,max-size=0,script-path=https://raw.githubusercontent.com/hackevin/tiktok-ruleset/refs/heads/main/bilibili_adskip.js

# 直播间广告
B站_直播间 = type=http-response,pattern=^https?://api\.live\.bilibili\.com/xlive/app-room/v1/index/getInfoByRoom,requires-body=true,max-size=0,script-path=https://raw.githubusercontent.com/hackevin/tiktok-ruleset/refs/heads/main/bilibili_adskip.js

# 我的页面广告入口
B站_我的页面 = type=http-response,pattern=^https?://app\.bilibili\.com/x/v2/account/mine,requires-body=true,max-size=0,script-path=https://raw.githubusercontent.com/hackevin/tiktok-ruleset/refs/heads/main/bilibili_adskip.js

# 开屏脚本处理（splash/show 接口）
B站_开屏 = type=http-response,pattern=^https?://app\.bilibili\.com/x/v2/splash/show,requires-body=true,max-size=0,script-path=https://raw.githubusercontent.com/hackevin/tiktok-ruleset/refs/heads/main/bilibili_adskip.js

[MITM]
hostname = %APPEND% app.bilibili.com,api.bilibili.com,api.live.bilibili.com
