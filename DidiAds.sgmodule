#!name=滴滴出行净化
#!desc=去除滴滴首页横幅广告、导航推广、用户中心营销卡片、钱包推广，精简底部导航
#!author=ZenmoFeiShi (Surge 适配)
#!version=2026.1.9
#!system=ios

[Rule]
# 广告 IP 直接拒绝（无需 MitM）
IP-CIDR,139.199.244.6/32,REJECT,no-resolve
IP-CIDR,113.46.225.9/32,REJECT,no-resolve
IP-CIDR,139.199.244.7/32,REJECT,no-resolve
IP-CIDR,113.46.225.8/32,REJECT,no-resolve
IP-CIDR,123.207.209.39/32,REJECT,no-resolve
IP-CIDR,123.207.209.60/32,REJECT,no-resolve
IP-CIDR,139.199.240.15/32,REJECT,no-resolve
IP-CIDR,139.199.240.12/32,REJECT,no-resolve
IP-CIDR,116.85.3.37/32,REJECT,no-resolve
IP-CIDR,162.14.157.2/32,REJECT,no-resolve
IP-CIDR,162.14.157.24/32,REJECT,no-resolve
IP-CIDR,116.85.1.0/32,REJECT,no-resolve
IP-CIDR,116.85.1.17/32,REJECT,no-resolve
IP-CIDR,116.85.1.22/32,REJECT,no-resolve
IP-CIDR,116.85.3.25/32,REJECT,no-resolve

# 广告域名
DOMAIN,gwp.xiaojukeji.com,REJECT

# 小程序首页横幅 / 推广接口
URL-REGEX,^https://res\.xiaojukeji\.com/resapi/activity/getMulti\?,REJECT
URL-REGEX,^https://res\.xiaojukeji\.com/resapi/activity/xpget,REJECT
URL-REGEX,^https://res\.xiaojukeji\.com/resapi/activity/mget,REJECT
URL-REGEX,^https://res\.xiaojukeji\.com/resapi/activity/getInsActivityV2,REJECT
URL-REGEX,^https://ct\.xiaojukeji\.com/agent/v3/feeds,REJECT
URL-REGEX,^https://freight\.xiaojukeji\.com/gateway,REJECT
URL-REGEX,^https://daijia\.kuaidadi\.com:443/gateway,REJECT
URL-REGEX,^https://conf\.diditaxi\.com\.cn/dynamic/conf,REJECT
URL-REGEX,^https://api\.udache\.com/gulfstream/watson/v1/bubble/getBubble,REJECT
URL-REGEX,^https://conf\.diditaxi\.com\.cn/homepage/v\d/other/slow,REJECT

[Script]
# 用户中心
Didi-UserCenter = type=http-response,pattern=^https://common\.diditaxi\.com\.cn/common/v\d/usercenter/me,requires-body=true,max-size=0,script-path=https://raw.githubusercontent.com/hackevin/tiktok-ruleset/refs/heads/main/didi_adskip.js

# 首页核心布局（精简导航）
Didi-HomeCore = type=http-response,pattern=^https://conf\.diditaxi\.com\.cn/homepage/v\d/core,requires-body=true,max-size=0,script-path=https://raw.githubusercontent.com/hackevin/tiktok-ruleset/refs/heads/main/didi_adskip.js

# 场景列表（移除优惠商城）
Didi-SceneList = type=http-response,pattern=^https://api\.udache\.com/gulfstream/pre-sale/v1/other/pGetSceneList,requires-body=true,max-size=0,script-path=https://raw.githubusercontent.com/hackevin/tiktok-ruleset/refs/heads/main/didi_adskip.js

# 顶部横幅
Didi-TopBanner = type=http-response,pattern=^https://conf\.diditaxi\.com\.cn/ota/na/yuantu/infoList,requires-body=true,max-size=0,script-path=https://raw.githubusercontent.com/hackevin/tiktok-ruleset/refs/heads/main/didi_adskip.js

# 海外首页布局
Didi-Oversea = type=http-response,pattern=^https://conf\.diditaxi\.com\.cn/homepage/v1/oversea/layout,requires-body=true,max-size=0,script-path=https://raw.githubusercontent.com/hackevin/tiktok-ruleset/refs/heads/main/didi_adskip.js

# 钱包首页推广卡片
Didi-Wallet = type=http-response,pattern=^https://mapi\.xiaojukeji\.com/passenger-wallet/api/v6/wallet/homepage,requires-body=true,max-size=0,script-path=https://raw.githubusercontent.com/hackevin/tiktok-ruleset/refs/heads/main/didi_adskip.js

# 打车首页布局推广卡片
Didi-HomeLayout = type=http-response,pattern=^https://api\.udache\.com/gulfstream/porsche/v1/dache_homepage_layout,requires-body=true,max-size=0,script-path=https://raw.githubusercontent.com/hackevin/tiktok-ruleset/refs/heads/main/didi_adskip.js

# 行程中推广组件
Didi-InTrip = type=http-response,pattern=^https://api\.udache\.com/gulfstream/passenger-center/v2/other/pInTripLayout,requires-body=true,max-size=0,script-path=https://raw.githubusercontent.com/hackevin/tiktok-ruleset/refs/heads/main/didi_adskip.js

# 用户中心布局营销卡片
Didi-Layout = type=http-response,pattern=^https://common\.diditaxi\.com\.cn/common/v5/usercenter/layout,requires-body=true,max-size=0,script-path=https://raw.githubusercontent.com/hackevin/tiktok-ruleset/refs/heads/main/didi_adskip.js

[MITM]
hostname = %APPEND% common.diditaxi.com.cn,conf.diditaxi.com.cn,api.udache.com,res.xiaojukeji.com,ct.xiaojukeji.com,mapi.xiaojukeji.com
