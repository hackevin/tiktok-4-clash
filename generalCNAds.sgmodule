#!name=国内App去广告增强
#!desc=通用广告SDK拦截 + B站/京东/美团/移动开屏去广告
#!author=claude
#!version=2.0.0
#!system=ios

[Rule]

# === 通用广告追踪 SDK ===
DOMAIN-SUFFIX,adjust.com,REJECT
DOMAIN-SUFFIX,appsflyer.com,REJECT
DOMAIN-SUFFIX,branch.io,REJECT

# === 腾讯广告 ===
DOMAIN-SUFFIX,gdt.qq.com,REJECT
DOMAIN-SUFFIX,adsmind.gdtimg.com,REJECT

# === 阿里广告 ===
DOMAIN-SUFFIX,alimama.com,REJECT
DOMAIN-SUFFIX,mmstat.com,REJECT

# === 京东广告 ===
DOMAIN,jdad.jd.com,REJECT

# === 字节广告 ===
DOMAIN-SUFFIX,pglstatp-toutiao.com,REJECT
DOMAIN-SUFFIX,byteoversea.com,REJECT

# === 百度广告 ===
DOMAIN,mobads.baidu.com,REJECT
DOMAIN,hm.baidu.com,REJECT

# === 美团广告（仅广告子域，不拦截主域）===
DOMAIN,ad.meituan.com,REJECT
DOMAIN,adfront.meituan.com,REJECT
DOMAIN,ad.dianping.com,REJECT

# === 网易广告 ===
DOMAIN,adgeo.163.com,REJECT

# === 小米追踪 ===
DOMAIN,tracking.miui.com,REJECT

# === 谷歌广告（国内 app 内嵌）===
DOMAIN-SUFFIX,doubleclick.net,REJECT
DOMAIN-SUFFIX,googlesyndication.com,REJECT

# === 移动广告域名 ===
DOMAIN,ad.10086.cn,REJECT

[Map Local]

# === B站开屏广告 ===
#^https?://app\.bilibili\.com/x/v2/splash data="https://raw.githubusercontent.com/blackmatrix7/ios_rule_script/refs/heads/master/blank/blank_dict.json"
#^https?://api\.bilibili\.com/x/v2/splash data="https://raw.githubusercontent.com/blackmatrix7/ios_rule_script/refs/heads/master/blank/blank_dict.json"

# === 京东开屏广告 ===
^https?://api\.m\.jd\.com/client\.action\?functionId=startUp data="https://raw.githubusercontent.com/blackmatrix7/ios_rule_script/refs/heads/master/blank/blank_dict.json"

# === 美团开屏广告 ===
^https?://wmapi\.meituan\.com/api/v\d+/loadInfo data="https://raw.githubusercontent.com/blackmatrix7/ios_rule_script/refs/heads/master/blank/blank_dict.json"

# === 大众点评开屏广告 ===
^https?://mapi\.dianping\.com/.*splash data="https://raw.githubusercontent.com/blackmatrix7/ios_rule_script/refs/heads/master/blank/blank_dict.json"

# === 中国移动开屏广告（新域名，2024+ 版本）===
^https?://client\.app\.coc\.10086\.cn/biz-orange/DN/init/startInit data="https://raw.githubusercontent.com/blackmatrix7/ios_rule_script/refs/heads/master/blank/blank_dict.json"
^https?://h\.app\.coc\.10086\.cn/ngpsie/psieappaiddsdkserver/merger/getSwitchAndInitList data="https://raw.githubusercontent.com/blackmatrix7/ios_rule_script/refs/heads/master/blank/blank_dict.json"

# === 中国移动开屏广告（旧域名兜底）===
^https?://clientaccess\.10086\.cn/biz-orange/DN/init/startInit data="https://raw.githubusercontent.com/blackmatrix7/ios_rule_script/refs/heads/master/blank/blank_dict.json"

[Script]
# B站去广告（需仓库内有 bilibili_adskip.js）
#Bilibili去广告 = type=http-response,pattern=^https?://app\.bilibili\.com/x/v2/feed/index,requires-body=true,max-size=0,script-path=https://raw.githubusercontent.com/hackevin/tiktok-ruleset/refs/heads/main/bilibili_adskip.js

[MITM]
hostname = %APPEND% app.bilibili.com,api.bilibili.com,api.m.jd.com,wmapi.meituan.com,mapi.dianping.com,client.app.coc.10086.cn,h.app.coc.10086.cn
