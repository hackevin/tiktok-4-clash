#!name=高德地图净化
#!desc=去除高德地图开屏广告、信息流广告、底部推广、搜索热词推广等
#!version=1.0.28
#!system=ios

[Rule]
DOMAIN-SUFFIX,optimus-ads.amap.com,DIRECT
URL-REGEX,^https?://.*\.amap\.com/ws/aos/alimama/splash_screen,REJECT-TINYGIF
URL-REGEX,^https?://.*\.amap\.com/v\d/ai_rec/,REJECT
URL-REGEX,^https?://.*\.amap\.com/ws/faas/amap-navigation/card-service-route-plan\?,REJECT
URL-REGEX,^https?://.*\.amap\.com/ws/asa/ads_attribution,REJECT
URL-REGEX,^https?://.*\.amap\.com/ws/boss/order_web/\w{8}_information,REJECT-TINYGIF
URL-REGEX,^https?://.*\.amap\.com/uploadimg/\w+\.gif,REJECT-TINYGIF
URL-REGEX,^https?://.*\.amap\.com/ws/valueadded/weather,REJECT
URL-REGEX,^http://amdc\.m\.taobao\.com,REJECT

[Script]
Amap-Splash = type=http-response,pattern=^https?://.*\.amap\.com/ws/valueadded/alimama/splash_screen,requires-body=true,max-size=131072,script-path=https://raw.githubusercontent.com/hackevin/tiktok-ruleset/refs/heads/main/amap_adskip.js
Amap-Notice = type=http-response,pattern=^https?://.*\.amap\.com/ws/message/notice/list,requires-body=true,max-size=131072,script-path=https://raw.githubusercontent.com/hackevin/tiktok-ruleset/refs/heads/main/amap_adskip.js
Amap-Updatable = type=http-response,pattern=^https?://.*\.amap\.com/ws/shield/frogserver/aocs/updatable,requires-body=true,max-size=131072,script-path=https://raw.githubusercontent.com/hackevin/tiktok-ruleset/refs/heads/main/amap_adskip.js
Amap-Nearby = type=http-response,pattern=^https?://.*\.amap\.com/ws/shield/search/nearbyrec_smart,requires-body=true,max-size=131072,script-path=https://raw.githubusercontent.com/hackevin/tiktok-ruleset/refs/heads/main/amap_adskip.js
Amap-Promotion = type=http-response,pattern=^https?://.*\.amap\.com/ws/promotion-web/resource,requires-body=true,max-size=131072,script-path=https://raw.githubusercontent.com/hackevin/tiktok-ruleset/refs/heads/main/amap_adskip.js
Amap-MainPage = type=http-response,pattern=^https?://.*\.amap\.com/ws/faas/amap-navigation/main-page,requires-body=true,max-size=131072,script-path=https://raw.githubusercontent.com/hackevin/tiktok-ruleset/refs/heads/main/amap_adskip.js
Amap-Msgbox = type=http-response,pattern=^https?://.*\.amap\.com/ws/msgbox/pull,requires-body=true,max-size=131072,script-path=https://raw.githubusercontent.com/hackevin/tiktok-ruleset/refs/heads/main/amap_adskip.js
Amap-Profile = type=http-response,pattern=^https?://.*\.amap\.com/ws/shield/dsp/profile/index/nodefaas,requires-body=true,max-size=131072,script-path=https://raw.githubusercontent.com/hackevin/tiktok-ruleset/refs/heads/main/amap_adskip.js
Amap-Hotword = type=http-response,pattern=^https?://.*\.amap\.com/ws/shield/search/new_hotword,requires-body=true,max-size=131072,script-path=https://raw.githubusercontent.com/hackevin/tiktok-ruleset/refs/heads/main/amap_adskip.js

[MITM]
hostname = %APPEND% m5.amap.com,m5-zb.amap.com,center.amap.com,amap-aos-info-nogw.amap.com,ai.amap.com
