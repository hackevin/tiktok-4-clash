#!name=小红书净化内置版（稳定长期版）
#!desc=去广告 + 精简推荐流 + 去水印字段（内置脚本，不依赖远程）
#!author=ChatGPT

[Rule]
DOMAIN-SUFFIX,xiaohongshu.com,DIRECT

[URL Rewrite]
# 广告接口拦截（基础层）
^https?:\/\/www\.xiaohongshu\.com\/api\/sns\/v\d\/(tag\/)?ads - reject
^https?:\/\/edith\.xiaohongshu\.com\/api\/sns\/v\d\/(tag\/)?ads - reject

# 上报/埋点
^https?:\/\/referee\.xiaohongshu\.com\/v\d\/stateReport - reject

# 开关控制
^https?:\/\/pages\.xiaohongshu\.com\/data\/native\/matrix_switches - reject


[Script]
xiaohongshu = type=http-response, pattern=^https?:\/\/edith\.xiaohongshu\.com\/api\/sns\/v\d\/.*, requires-body=1, max-size=0, script-path=inline

# ===== 内置脚本开始 =====
<script>
try {
    let body = $response.body;
    let obj = JSON.parse(body);

    // 通用安全判断
    if (!obj) $done({body});

    // ===== 1. 去广告字段 =====
    if (obj.data) {
        if (Array.isArray(obj.data)) {
            obj.data = obj.data.filter(item => {
                if (!item) return false;

                // 过滤广告卡片
                if (item.model_type && item.model_type.toLowerCase().includes("ad")) return false;
                if (item.note_attributes && item.note_attributes.includes("ad")) return false;
                if (item.ads_info) return false;

                return true;
            });
        }

        // ===== 2. 精简推荐流 =====
        if (obj.data.items && Array.isArray(obj.data.items)) {
            obj.data.items = obj.data.items.filter(item => {
                if (!item) return false;

                if (item.model_type && item.model_type.toLowerCase().includes("ad")) return false;
                if (item.note_attributes && item.note_attributes.includes("ad")) return false;

                return true;
            });
        }
    }

    // ===== 3. 去水印字段 =====
    if (obj.data && obj.data.note_list) {
        obj.data.note_list.forEach(note => {
            if (note.video && note.video.consumer) {
                // 删除水印字段（部分版本有效）
                delete note.video.consumer.origin_video_key;
                delete note.video.consumer.video_key;
            }
        });
    }

    // ===== 4. 清理多余字段 =====
    if (obj.data && obj.data.ads_groups) {
        delete obj.data.ads_groups;
    }

    $done({body: JSON.stringify(obj)});
} catch (e) {
    $done({});
}
</script>
# ===== 内置脚本结束 =====


[MITM]
hostname = %APPEND% edith.xiaohongshu.com
