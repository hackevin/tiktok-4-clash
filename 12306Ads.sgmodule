#!name=12306 净化
#!desc=去除开屏及信息流广告
#!author=ddgksf2013 (hackevin 适配)
#!icon=https://raw.githubusercontent.com/Koolson/Qure/master/IconSet/Color/12306.png

[Rule]
# 广告域名直接拦截（无需 MITM）
DOMAIN,ad.12306.cn,REJECT

[Script]
# 广告接口返回伪造空数据（需 MITM ad.12306.cn）
12306去广告 = type=http-request,pattern=^https?://ad\.12306\.cn/ad/ser/getAdList,requires-body=true,max-size=131072,script-path=https://raw.githubusercontent.com/ddgksf2013/Scripts/master/12306.js

[MITM]
hostname = %APPEND% ad.12306.cn
