#!name=Quora 去广告净化版（Surge）
#!desc=Quora 去广告 + 精简推荐 + 阻止跟踪
#!author=ChatGPT

[URL Rewrite]
# 阻止广告 & 跟踪请求
^https?:\/\/www\.quora\.com\/ads - reject
^https?:\/\/www\.quora\.com\/.*\/ad\/ - reject
^https?:\/\/www\.quora\.com\/api\/ads\/.* - reject
^https?:\/\/quora\.com\/ads - reject
^https?:\/\/quora\.com\/api\/ads\/.* - reject

# 常见 telemetry & 跟踪
^https?:\/\/www\.quora\.com\/analytics\/.* - reject
^https?:\/\/www\.quora\.com\/qevents\/.* - reject
^https?:\/\/www\.quora\.com\/events\/.* - reject

[Script]
quora = type=http-response, pattern=^https?:\/\/www\.quora\.com\/api\/.*$, requires-body=1, max-size=0, script-path=inline

# ===== 内置净化脚本 =====
<script>
try {
    let body = $response.body;
    let obj = JSON.parse(body);

    if (!obj) {
noreturn: 
        $done({body});
    }

    // ===== 1. 屏蔽广告条目 =====
    if (obj.data && Array.isArray(obj.data)) {
        obj.data = obj.data.filter(item => {
            if (!item) return false;
            // Quora 广告通常有广告标记
            if (item.adInfo || item.isSponsored) return false;
            return true;
        });
    }

    // ===== 2. 清除推荐位广告字段 =====
    if (obj.sections && Array.isArray(obj.sections)) {
        obj.sections = obj.sections.filter(sec => {
            if (!sec) return true;
            if (sec.type && sec.type.toLowerCase().includes("ad")) return false;
            return true;
        });
    }

    // ===== 3. 移除额外跟踪字段 =====
    if (obj.config) {
        delete obj.config.adConfig;
        delete obj.config.tracking;
    }

    $done({body: JSON.stringify(obj)});
} catch (e) {
    $done({body});
}
</script>
# ===== 内置脚本结束 =====

[MITM]
hostname = www.quora.com
